{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["DOM", "DOM.Iterable", "ES2018"],
    "module": "none",
    "moduleResolution": "node",
    "rootDir": "ts",
    "outDir": "dist/js",
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["ts/**/*.ts", "ts/**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
