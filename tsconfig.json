{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["DOM", "DOM.Iterable", "ES2018"],
    "module": "none",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["js/**/*.ts", "js/**/*.d.ts"],
  "exclude": ["js/**/*.js", "node_modules"]
}
